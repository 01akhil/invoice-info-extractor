# Copy to .env and adjust. Loaded from project root by config.settings (python-dotenv).

# --- Paths ---
# IMAGES_DIR=
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# --- Gemini (set in your environment or here) ---
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-3.1-flash-lite-preview
# GEMINI_RPM=12
# GEMINI_429_MAX_RETRIES=12

# --- Redis & pipeline ---
# REDIS_URL=redis://127.0.0.1:6379/0
# PIPELINE_WAIT_TIMEOUT_SEC=3600
# OCR_PROCESSES=4
# LLM_THREAD_POOL=1
# POST_OCR_THREADS=2
# VALIDATE_THREADS=2

# --- Metrics / evaluation artifacts ---
# EVAL_KEEP_METRICS=0
# EVAL_ACCUMULATE_HUMAN_REVIEW=0

# --- Google Form (submit uses only valid_invoices from pipeline_export.json) ---
# SUBMIT_AFTER_PIPELINE=1
# SUBMIT_FORM_URL=
# SUBMIT_ENTRY_VENDOR=
# SUBMIT_ENTRY_DATE=
# SUBMIT_ENTRY_TOTAL=
# SUBMIT_MAX_RETRIES=3
# SUBMIT_DELAY=0.5
# SUBMIT_TIMEOUT=15
